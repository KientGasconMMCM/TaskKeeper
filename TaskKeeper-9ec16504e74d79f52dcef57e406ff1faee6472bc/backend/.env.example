PORT=5000
JWT_SECRET=your-secret-key-here

# PostgreSQL connection string (required)
# Works with Supabase, Neon, or another hosted PostgreSQL provider.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# SMTP Email Settings (required for password reset emails)
# You can use Gmail, Outlook, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=CramTaskGPT <your-email@gmail.com>

# Google Classroom Integration
# Get these from https://console.cloud.google.com/
# 1. Create a new Google Cloud Project
# 2. Enable Google Classroom API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:3000/api/google-classroom/auth/callback (or your production URL)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/google-classroom/auth/callback

# =========================
# OpenAI (ChatGPT) settings
# =========================
OPENAI_API_KEY=your-openai-api-key
# Optional: defaults to gpt-4o-mini in code
OPENAI_MODEL=gpt-4o-mini
# Optional: defaults to https://api.openai.com/v1/chat/completions in code
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
