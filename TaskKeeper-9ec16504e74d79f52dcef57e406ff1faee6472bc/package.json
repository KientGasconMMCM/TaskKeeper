    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "google-auth-library": "^8.8.0",
    "googleapis": "^118.0.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.13.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
